class Solution:
    def findMin(self, nums: List[int]) -> int:
        i,j=0,len(nums)-1
        while(i<j):
            mid=(i+j)//2
            if i==j:
                return nums[i]
            elif mid!=len(nums)-1 and nums[mid]>nums[mid+1]:
                i=mid+1
            elif nums[mid]<=nums[mid+1]:
                j=mid
        return nums[i]
