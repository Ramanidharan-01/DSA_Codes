class Solution:
    def canConstruct(self, ransomNote: str, magazine: str) -> bool:
        d=dict()
        for i in magazine:
            if i not in d:
                d[i]=1
            else:
                d[i]+=1
        for j in ransomNote:
            if j not in d:
                return False
            else:
                d[j]-=1
        for k in d.values():
            if k<0:
                return False
        return True
        
