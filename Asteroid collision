class Solution:
    def asteroidCollision(self, asteroids: List[int]) -> List[int]:
        stack=[]
        for asteroid in asteroids:
            if (len(stack)>0 and  stack[-1]>0 and asteroid<0 ):
                while(len(stack)>0 and stack[-1]<-asteroid and stack[-1]>0):
                    stack.pop()
                if (len(stack)>0 and stack[-1] > -asteroid):
                    continue
                elif (len(stack)>0 and stack[-1]==-asteroid):
                    stack.pop()
                else:
                    stack.append(asteroid)
            else:
                stack.append(asteroid)
        return stack
