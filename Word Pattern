class Solution:
    def wordPattern(self, pattern: str, s: str) -> bool:
        l=list(s.strip().split())
        m=len(pattern)
        n=len(l)
        if m!=n:
            return False
        d=dict()
        for i in range(m):
            if pattern[i] not in d:
                if l[i] in d.values():
                    return False
                d[pattern[i]]=l[i]
            else:
                if d[pattern[i]]!=l[i]:
                    return False
        return True
