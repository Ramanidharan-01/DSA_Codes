class Solution:
    def carFleet(self, target: int, position: List[int], speed: List[int]) -> int:
        cars=[]
        for i in range(len(position)):
            cars.append([position[i],speed[i]])
        cars.sort(reverse=True)
        print(cars)
        stack = []
        for car in cars:
            time=(target - car[0])/car[1]
            if (len(stack)==0 or stack[-1]<time):
                stack.append(time)
        return len(stack)
